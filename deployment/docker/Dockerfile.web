# ---------------------------------------------------------------------------
# Dockerfile.web — Dashboard web frontend (nginx + Vite SPA)
# ---------------------------------------------------------------------------
# Multi-stage build:
#   1. "builder"  — installs npm dependencies, builds the Vite production bundle
#   2. "runtime"  — lightweight nginx:alpine serving the static SPA
#
# Build context: project root (../../ from this file)
# Build command:
#   docker build -f deployment/docker/Dockerfile.web -t autodoc-web .
# ---------------------------------------------------------------------------

# ===== Stage 1: Build =====
FROM node:20-alpine AS builder

WORKDIR /app

# Copy dependency manifests first for optimal layer caching.
# Changes to application code alone will NOT invalidate the dependency layer.
COPY web/package.json web/package-lock.json ./

RUN npm ci

# Copy application source code
COPY web/ .

# Build the Vite production bundle
RUN npm run build


# ===== Stage 2: Runtime =====
FROM nginx:alpine

LABEL org.opencontainers.image.title="autodoc-web" \
      org.opencontainers.image.description="Dashboard web frontend for autodoc-adk" \
      org.opencontainers.image.source="https://github.com/autodoc-adk/autodoc-adk" \
      org.opencontainers.image.licenses="MIT"

# Create a non-root user for security
RUN addgroup -S autodoc && adduser -S autodoc -G autodoc

# Copy the built SPA from the builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx config template — nginx:alpine runs envsubst on *.template files
# in /etc/nginx/templates/ at startup, outputting to /etc/nginx/conf.d/.
# Only API_UPSTREAM is substituted; other $variables (e.g. $uri) are preserved.
COPY deployment/docker/nginx-web.conf.template /etc/nginx/templates/default.conf.template

# Remove the default config shipped by the nginx image
RUN rm -f /etc/nginx/conf.d/default.conf

# Write PID to /tmp so non-root user can start nginx (container /run may be tmpfs)
RUN sed -i 's|/run/nginx.pid|/tmp/nginx.pid|' /etc/nginx/nginx.conf

# Ensure non-root user can write to required nginx directories
RUN chown -R autodoc:autodoc /usr/share/nginx/html \
                              /var/cache/nginx \
                              /var/log/nginx \
                              /etc/nginx/conf.d

# Default API upstream — override via environment variable at runtime
ENV API_UPSTREAM=autodoc-api:8080

# Restrict envsubst to only replace API_UPSTREAM (preserve nginx $uri etc.)
ENV NGINX_ENVSUBST_FILTER=API_UPSTREAM

# Switch to non-root user
USER autodoc

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget -qO- http://localhost:3000/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
