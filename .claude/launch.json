{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8080", "--reload", "--loop", "asyncio"],
      "port": 8080
    },
    {
      "name": "prefect-worker",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "prefect", "worker", "start", "--pool", "local-dev"],
      "port": 4200
    }
  ]
}
